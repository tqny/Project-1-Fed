generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Opportunity {
  id                 String   @id @default(cuid())
  source             String   @default("sam")
  sourceId           String   @unique
  title              String
  agency             String
  office             String?
  postedDate         DateTime
  dueDate            DateTime?
  naics              String
  setAside           String?
  placeOfPerformance String?
  waRelevant         Boolean  @default(false)
  url                String
  description        String?
  enrichment         String?
  scoreTotal         Float    @default(0)
  scoreBreakdown     String   @default("{}")
  brief              String?
  status             String   @default("new")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([agency])
  @@index([scoreTotal])
}

model RefreshRun {
  id            String   @id @default(cuid())
  status        String   @default("running")
  countFetched  Int      @default(0)
  countUpserted Int      @default(0)
  countEnriched Int      @default(0)
  countScored   Int      @default(0)
  countBriefed  Int      @default(0)
  errors        String   @default("[]")
  startedAt     DateTime @default(now())
  finishedAt    DateTime?

  @@index([startedAt])
}

model Lead {
  id                   String   @id @default(cuid())
  orgName              String
  agencyName           String
  segment              String
  website              String?
  phone                String?
  headcount            Int
  annualBudgetM        Float
  relatedSpendM        Float
  governanceRoleTitle  String?
  governanceRolePresent Boolean @default(false)
  procurementReadiness Int
  complianceUrgency    Int
  regulatoryComplexity Int
  cyberPressure        Int
  icpScore             Float    @default(0)
  icpGrade             String   @default("D")
  fitBand              String   @default("Outside")
  considerable         Boolean  @default(false)
  status               String   @default("generated")
  priorityRank         Int?
  rationale            String   @default("{}")
  fieldProvenance      String   @default("{}")
  generatedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([agencyName])
  @@index([icpScore])
  @@index([icpGrade])
  @@index([fitBand])
  @@index([considerable])
}

model LeadRun {
  id             String   @id @default(cuid())
  runType        String
  status         String   @default("running")
  requestedCount Int?
  generatedCount Int      @default(0)
  sortedCount    Int      @default(0)
  summary        String   @default("{}")
  errors         String   @default("[]")
  startedAt      DateTime @default(now())
  finishedAt     DateTime?

  @@index([runType, startedAt])
}
